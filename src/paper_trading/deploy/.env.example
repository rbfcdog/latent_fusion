# Broker keys — copy to .env and fill in.
# livepaper (default) needs NONE of these — it streams Binance testnet market data
# and simulates fills. Only set these when using --broker binance or --broker alpaca.

# Alpaca paper trading (https://app.alpaca.markets/paper/dashboard/overview)
ALPACA_API_KEY=
ALPACA_API_SECRET=

# Binance Spot Testnet (https://testnet.binance.vision/ — GitHub login)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# (existing project keys — not used by paper_trading)
# OPENAI_API_KEY=
# LSE_API_KEY=
